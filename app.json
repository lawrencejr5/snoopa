{
  "expo": {
    "name": "Snoopa",
    "slug": "snoopa",
    "version": "2.0.3",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/43bf9433-2262-4db8-af1c-1bda9b67cbf6"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "com.lawrencejr.snoopa",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lawrencejr.snoopa",
      "icon": "./assets/images/icon-ios.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#121212"
      },
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false,
      "package": "com.lawrencejr.snoopa",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Snoopa uses your device identifier to deliver personalized ads and relevant notifications."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#EBEBDF",
          "sounds": [
            "./assets/sounds/dog_bark_single.wav"
          ]
        }
      ],
      "expo-updates",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7078901325871517~7314635387",
          "iosAppId": "ca-app-pub-7078901325871517~9953396692"
        }
      ],
      "expo-tracking-transparency"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "43bf9433-2262-4db8-af1c-1bda9b67cbf6"
      }
    },
    "owner": "lawrencejr"
  }
}
